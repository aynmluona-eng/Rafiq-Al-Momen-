<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_main_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="20dp"
    android:layoutDirection="rtl">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:baselineAligned="false">

        <!-- Countdown (Start/Right side in RTL) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="start">

            <TextView
                android:id="@+id/text_next_prayer_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="بقي على العصر"
                android:textColor="@color/widget_text_secondary"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/text_countdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="02:02:24"
                android:textColor="@color/widget_text_primary"
                android:textSize="32sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Location & Date (End/Left side in RTL) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layoutDirection="rtl">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@android:drawable/ic_menu_mylocation"
                    android:tint="@color/widget_text_secondary" />

                <TextView
                    android:id="@+id/text_location_day"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="مكة المكرمة، الخميس"
                    android:textColor="@color/widget_text_primary"
                    android:textSize="15sp"
                    android:layout_marginEnd="4dp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <TextView
                android:id="@+id/text_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="20 ذو القعدة • 7 مايو"
                android:textColor="@color/widget_text_secondary"
                android:textSize="14sp"
                android:layout_marginTop="6dp" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Prayers Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="6"
        android:gravity="center_vertical">

        <!-- Fajr (Displays first on right in RTL) -->
        <LinearLayout
            android:id="@+id/prayer_fajr_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="فجر"
                android:textColor="@color/widget_text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/text_fajr"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="4:40"
                android:textColor="@color/widget_text_secondary"
                android:textSize="14sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>
        
        <!-- Sunrise -->
        <LinearLayout
            android:id="@+id/prayer_sunrise_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="شروق"
                android:textColor="@color/widget_text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/text_sunrise"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="6:13"
                android:textColor="@color/widget_text_secondary"
                android:textSize="14sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>
        
        <!-- Dhuhr -->
        <LinearLayout
            android:id="@+id/prayer_dhuhr_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ظهر"
                android:textColor="@color/widget_text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/text_dhuhr"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1:07"
                android:textColor="@color/widget_text_secondary"
                android:textSize="14sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Asr -->
        <LinearLayout
            android:id="@+id/prayer_asr_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="عصر"
                android:textColor="@color/widget_accent"
                android:textSize="14sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/text_asr"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="4:45"
                android:textColor="@color/widget_accent"
                android:textSize="14sp"
                android:layout_marginTop="4dp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Maghrib -->
        <LinearLayout
            android:id="@+id/prayer_maghrib_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="مغرب"
                android:textColor="@color/widget_text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/text_maghrib"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="7:56"
                android:textColor="@color/widget_text_secondary"
                android:textSize="14sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>
        
        <!-- Isha -->
        <LinearLayout
            android:id="@+id/prayer_isha_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="عشاء"
                android:textColor="@color/widget_text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/text_isha"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="9:26"
                android:textColor="@color/widget_text_secondary"
                android:textSize="14sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.4" />

    <!-- Midnight / Last Third -->
    <TextView
        android:id="@+id/text_night_details"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="نصف الليل 12:17  |  الثلث الأخير 1:44"
        android:textColor="@color/widget_text_secondary"
        android:textSize="13sp" />

</LinearLayout>
